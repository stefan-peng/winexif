<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WinExif.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinExif"
    xmlns:models="using:WinExif.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinExif">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="WinExif">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid x:Name="PaneGrid" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="WorkspaceRow" Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition x:Name="PhotoPaneRow" Height="300" />
            </Grid.RowDefinitions>

            <CommandBar DefaultLabelPosition="Right" OverflowButtonVisibility="Auto">
                <AppBarButton x:Uid="AddPhotosButton" Click="AddPhotos_Click" />
                <AppBarButton x:Uid="LoadGpxButton" Click="LoadGpx_Click" />
                <AppBarButton x:Uid="ApplyGpxButton" Click="ApplyGpx_Click" />
                <AppBarSeparator />
                <AppBarButton x:Uid="RemoveSelectedButton" Click="RemoveSelected_Click" />
                <AppBarButton x:Uid="SaveSelectedButton" Click="SaveSelected_Click" />
                <AppBarSeparator />
                <AppBarButton x:Uid="FitMapButton" Click="FitMap_Click" />
            </CommandBar>

            <InfoBar
                Grid.Row="1"
                Margin="12,0,12,12"
                IsOpen="{x:Bind IsStatusOpen, Mode=OneWay}"
                IsClosable="False"
                Message="{x:Bind StatusMessage, Mode=OneWay}"
                Severity="{x:Bind StatusSeverity, Mode=OneWay}" />

            <Grid x:Name="WorkspaceGrid" Grid.Row="2" Margin="12,4,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="340" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock
                                x:Uid="SidebarTitleText"
                                FontSize="24"
                                FontWeight="SemiBold" />
                            <TextBlock
                                x:Uid="SidebarCaptionText"
                                Opacity="0.72" />
                        </StackPanel>

                        <Border Style="{StaticResource SidebarCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock
                                    x:Uid="SourcesSectionTitleText"
                                    FontSize="18"
                                    FontWeight="SemiBold" />
                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock
                                        x:Uid="GpxLabelText"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind GpxSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                                    <TextBlock
                                        x:Uid="ExifToolLabelText"
                                        Grid.Row="1"
                                        VerticalAlignment="Center" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBox
                                            x:Uid="ExifToolPathTextBox"
                                            Width="190"
                                            Text="{x:Bind ExifToolPath, Mode=TwoWay}" />
                                        <Button
                                            x:Uid="BrowseExifToolButton"
                                            Click="BrowseExifTool_Click" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SidebarCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock
                                    x:Uid="TimeSectionTitleText"
                                    FontSize="18"
                                    FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <NumberBox
                                        x:Name="OffsetMinutesBox"
                                        x:Uid="OffsetMinutesBox"
                                        Width="160"
                                        SmallChange="1"
                                        SpinButtonPlacementMode="Compact"
                                        Value="{x:Bind OffsetMinutes, Mode=TwoWay}" />
                                    <CheckBox
                                        x:Uid="RewriteCaptureTimeCheckBox"
                                        VerticalAlignment="Bottom"
                                        IsChecked="{x:Bind RewriteCaptureTime, Mode=TwoWay}" />
                                </StackPanel>
                                <TextBlock Text="{x:Bind OffsetSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SidebarCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock
                                    x:Uid="ManualPinSectionTitleText"
                                    FontSize="18"
                                    FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind MapClickSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <Button
                                    x:Uid="TagSelectedAtClickButton"
                                    Click="TagSelectedAtClick_Click"
                                    HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SidebarCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="SelectionSectionTitleText"
                                    FontSize="18"
                                    FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind SelectionSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <local:ResizeCursorGrid
                    x:Name="VerticalSplitter"
                    Grid.Column="1"
                    Margin="6,12"
                    Background="Transparent"
                    CursorShape="SizeWestEast"
                    PointerCanceled="VerticalSplitter_PointerCanceled"
                    PointerCaptureLost="VerticalSplitter_PointerCaptureLost"
                    PointerEntered="VerticalSplitter_PointerEnteredVisual"
                    PointerExited="VerticalSplitter_PointerExitedVisual"
                    PointerMoved="VerticalSplitter_PointerMoved"
                    PointerPressed="VerticalSplitter_PointerPressed"
                    PointerReleased="VerticalSplitter_PointerReleased"
                    AutomationProperties.Name="Resize left and right panes"
                    AutomationProperties.AutomationId="VerticalPaneSplitter">
                    <Grid
                        Width="8"
                        Height="72"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False">
                        <Border
                            x:Name="VerticalSplitterGlow"
                            Width="8"
                            Height="72"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                            CornerRadius="{StaticResource AppGripCornerRadius}"
                            Opacity="0" />
                        <Border
                            x:Name="VerticalSplitterHandle"
                            Width="3"
                            Height="48"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{ThemeResource TextFillColorSecondaryBrush}"
                            CornerRadius="{StaticResource AppGripCornerRadius}"
                            Opacity="0.4" />
                    </Grid>
                </local:ResizeCursorGrid>

                <Grid
                    x:Name="PreviewMapGrid"
                    Grid.Column="2"
                    Margin="2,0,0,0"
                    RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="PreviewPaneRow" Height="208" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="MapPaneRow" Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        x:Uid="ImagePreviewTitleText"
                        Margin="0,0,0,10"
                        FontSize="20"
                        FontWeight="SemiBold" />

                    <Border
                        Grid.Row="1"
                        Style="{StaticResource PreviewCardStyle}">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind SelectedPhotoPreviewTitle, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Opacity="0.72"
                                    Text="{x:Bind SelectedPhotoPreviewStatus, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Border
                                Grid.Row="1"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="{StaticResource AppNestedCornerRadius}">
                                <Image
                                    Source="{x:Bind SelectedPhotoPreviewSource, Mode=OneWay}"
                                    Stretch="Uniform"
                                    AutomationProperties.Name="Selected photo preview"
                                    AutomationProperties.AutomationId="SelectedPhotoPreviewImage" />
                            </Border>
                        </Grid>
                    </Border>

                    <local:ResizeCursorGrid
                        x:Name="PreviewMapSplitter"
                        Grid.Row="2"
                        Margin="0,4"
                        Background="Transparent"
                        CursorShape="SizeNorthSouth"
                        PointerCanceled="PreviewMapSplitter_PointerCanceled"
                        PointerCaptureLost="PreviewMapSplitter_PointerCaptureLost"
                        PointerEntered="PreviewMapSplitter_PointerEnteredVisual"
                        PointerExited="PreviewMapSplitter_PointerExitedVisual"
                        PointerMoved="PreviewMapSplitter_PointerMoved"
                        PointerPressed="PreviewMapSplitter_PointerPressed"
                        PointerReleased="PreviewMapSplitter_PointerReleased"
                        AutomationProperties.Name="Resize image preview and map preview"
                        AutomationProperties.AutomationId="PreviewMapSplitter">
                        <Grid Height="8" VerticalAlignment="Center" IsHitTestVisible="False">
                            <Border
                                x:Name="PreviewMapSplitterGlow"
                                Height="8"
                                Width="84"
                                HorizontalAlignment="Center"
                                Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                CornerRadius="{StaticResource AppGripCornerRadius}"
                                Opacity="0" />
                            <Border
                                x:Name="PreviewMapSplitterHandle"
                                Height="3"
                                Width="56"
                                HorizontalAlignment="Center"
                                Background="{ThemeResource TextFillColorSecondaryBrush}"
                                CornerRadius="{StaticResource AppGripCornerRadius}"
                                Opacity="0.4" />
                        </Grid>
                    </local:ResizeCursorGrid>

                    <Grid Grid.Row="3" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Uid="MapPreviewTitleText"
                            Margin="0,8,0,10"
                            FontSize="20"
                            FontWeight="SemiBold" />

                        <Border
                            Grid.Column="1"
                            Padding="10"
                            Background="{ThemeResource LayerFillColorAltBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource AppCompactCornerRadius}"
                            AllowDrop="True"
                            DragOver="MapDropTarget_DragOver"
                            Drop="MapDropTarget_Drop">
                            <StackPanel Width="188" Spacing="2">
                                <TextBlock
                                    x:Uid="MapDropTargetTitleText"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    x:Uid="MapDropTargetCaptionText"
                                    FontSize="12"
                                    Opacity="0.72"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border
                        Grid.Row="4"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="{StaticResource AppNestedCornerRadius}">
                        <WebView2
                            x:Name="MapView"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            NavigationCompleted="MapView_NavigationCompleted" />
                    </Border>
                </Grid>
            </Grid>

            <local:ResizeCursorGrid
                x:Name="HorizontalSplitter"
                Grid.Row="3"
                Margin="12,6,12,6"
                Background="Transparent"
                CursorShape="SizeNorthSouth"
                PointerCanceled="HorizontalSplitter_PointerCanceled"
                PointerCaptureLost="HorizontalSplitter_PointerCaptureLost"
                PointerEntered="HorizontalSplitter_PointerEnteredVisual"
                PointerExited="HorizontalSplitter_PointerExitedVisual"
                PointerMoved="HorizontalSplitter_PointerMoved"
                PointerPressed="HorizontalSplitter_PointerPressed"
                PointerReleased="HorizontalSplitter_PointerReleased"
                AutomationProperties.Name="Resize top and bottom panes"
                AutomationProperties.AutomationId="HorizontalPaneSplitter">
                <Grid Height="8" VerticalAlignment="Center" IsHitTestVisible="False">
                    <Border
                        x:Name="HorizontalSplitterGlow"
                        Height="8"
                        Width="84"
                        HorizontalAlignment="Center"
                        Background="{ThemeResource AccentFillColorSecondaryBrush}"
                        CornerRadius="{StaticResource AppGripCornerRadius}"
                        Opacity="0" />
                    <Border
                        x:Name="HorizontalSplitterHandle"
                        Height="3"
                        Width="56"
                        HorizontalAlignment="Center"
                        Background="{ThemeResource TextFillColorSecondaryBrush}"
                        CornerRadius="{StaticResource AppGripCornerRadius}"
                        Opacity="0.4" />
                </Grid>
            </local:ResizeCursorGrid>

            <Border
                Grid.Row="4"
                Margin="{StaticResource AppSectionMargin}"
                Style="{StaticResource SectionPaneStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="2,2,2,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Uid="PhotosSectionTitleText"
                            FontSize="20"
                            FontWeight="SemiBold" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="{x:Bind PhotoCountSummary, Mode=OneWay}" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="4"
                            Background="{ThemeResource LayerFillColorAltBrush}"
                            CornerRadius="{StaticResource AppCompactCornerRadius}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="175" />
                                    <ColumnDefinition Width="175" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    x:Name="FileSortHeaderButton"
                                    x:Uid="FileSortHeaderButton"
                                    Click="PhotoSortHeader_Click"
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Tag="FileName"
                                    AutomationProperties.AutomationId="FileSortHeaderButton">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Uid="FileSortHeaderLabel" FontWeight="SemiBold" />
                                        <TextBlock
                                            x:Name="FileSortHeaderIndicator"
                                            Grid.Column="1"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="CaptureTimeSortHeaderButton"
                                    x:Uid="CaptureTimeSortHeaderButton"
                                    Grid.Column="1"
                                    Click="PhotoSortHeader_Click"
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Tag="CaptureTime"
                                    AutomationProperties.AutomationId="CaptureTimeSortHeaderButton">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Uid="CaptureTimeSortHeaderLabel" FontWeight="SemiBold" />
                                        <TextBlock
                                            x:Name="CaptureTimeSortHeaderIndicator"
                                            Grid.Column="1"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="UpdatedTimeSortHeaderButton"
                                    x:Uid="UpdatedTimeSortHeaderButton"
                                    Grid.Column="2"
                                    Click="PhotoSortHeader_Click"
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Tag="AdjustedCaptureTime"
                                    AutomationProperties.AutomationId="UpdatedTimeSortHeaderButton">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Uid="UpdatedTimeSortHeaderLabel" FontWeight="SemiBold" />
                                        <TextBlock
                                            x:Name="UpdatedTimeSortHeaderIndicator"
                                            Grid.Column="1"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="LatitudeSortHeaderButton"
                                    x:Uid="LatitudeSortHeaderButton"
                                    Grid.Column="3"
                                    Click="PhotoSortHeader_Click"
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Tag="Latitude"
                                    AutomationProperties.AutomationId="LatitudeSortHeaderButton">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Uid="LatitudeSortHeaderLabel" FontWeight="SemiBold" />
                                        <TextBlock
                                            x:Name="LatitudeSortHeaderIndicator"
                                            Grid.Column="1"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="LongitudeSortHeaderButton"
                                    x:Uid="LongitudeSortHeaderButton"
                                    Grid.Column="4"
                                    Click="PhotoSortHeader_Click"
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Tag="Longitude"
                                    AutomationProperties.AutomationId="LongitudeSortHeaderButton">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Uid="LongitudeSortHeaderLabel" FontWeight="SemiBold" />
                                        <TextBlock
                                            x:Name="LongitudeSortHeaderIndicator"
                                            Grid.Column="1"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="SourceSortHeaderButton"
                                    x:Uid="SourceSortHeaderButton"
                                    Grid.Column="5"
                                    Click="PhotoSortHeader_Click"
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Tag="CoordinateSource"
                                    AutomationProperties.AutomationId="SourceSortHeaderButton">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Uid="SourceSortHeaderLabel" FontWeight="SemiBold" />
                                        <TextBlock
                                            x:Name="SourceSortHeaderIndicator"
                                            Grid.Column="1"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="StatusSortHeaderButton"
                                    x:Uid="StatusSortHeaderButton"
                                    Grid.Column="6"
                                    Click="PhotoSortHeader_Click"
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Tag="Status"
                                    AutomationProperties.AutomationId="StatusSortHeaderButton">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Uid="StatusSortHeaderLabel" FontWeight="SemiBold" />
                                        <TextBlock
                                            x:Name="StatusSortHeaderIndicator"
                                            Grid.Column="1"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Button>
                            </Grid>
                        </Border>

                        <ListView
                            x:Name="PhotoListView"
                            x:Uid="PhotoListView"
                            Grid.Row="1"
                            Margin="0,6,0,0"
                            CanDragItems="True"
                            IsMultiSelectCheckBoxEnabled="True"
                            ItemContainerStyle="{StaticResource PhotoListItemStyle}"
                            ItemsSource="{x:Bind Photos, Mode=OneWay}"
                            SelectionMode="Extended"
                            SelectionChanged="PhotoListView_SelectionChanged"
                            DragItemsStarting="PhotoListView_DragItemsStarting">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:PhotoItem">
                                    <Grid MinHeight="40" Padding="8,6,24,6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="175" />
                                            <ColumnDefinition Width="175" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind CaptureTimeDisplay}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind AdjustedCaptureTimeDisplay}" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind LatitudeDisplay}" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind LongitudeDisplay}" />
                                        <TextBlock Grid.Column="5" Text="{x:Bind CoordinateSource}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="6" Text="{x:Bind Status}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
