<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WinExif.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinExif"
    xmlns:models="using:WinExif.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinExif">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="WinExif">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid x:Name="PaneGrid" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="WorkspaceRow" Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition x:Name="PhotoPaneRow" Height="300" />
            </Grid.RowDefinitions>

            <CommandBar DefaultLabelPosition="Right" OverflowButtonVisibility="Auto">
                <AppBarButton Click="AddPhotos_Click" Label="Add Photos" />
                <AppBarButton Click="LoadGpx_Click" Label="Load GPX" />
                <AppBarButton Click="ApplyGpx_Click" Label="Apply GPX Tags" />
                <AppBarSeparator />
                <AppBarButton Click="RemoveSelected_Click" Label="Remove Selected" />
                <AppBarButton Click="SaveSelected_Click" Label="Save Selected" />
                <AppBarSeparator />
                <AppBarButton Click="FitMap_Click" Label="Fit Map" />
            </CommandBar>

            <InfoBar
                Grid.Row="1"
                Margin="12,0,12,12"
                IsOpen="{x:Bind IsStatusOpen, Mode=OneWay}"
                IsClosable="False"
                Message="{x:Bind StatusMessage, Mode=OneWay}"
                Severity="{x:Bind StatusSeverity, Mode=OneWay}" />

            <Grid x:Name="WorkspaceGrid" Grid.Row="2" Margin="12,0,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="360" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Photo Geotagging" />
                                <TextBlock Opacity="0.75" Text="Load JPEG or RAW files, align capture times to a GPX track, preview locations, then write metadata through ExifTool." TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="16">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Sources" />
                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock VerticalAlignment="Center" Text="GPX" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind GpxSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="ExifTool" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBox Width="200" PlaceholderText="Auto-detect exiftool.exe" Text="{x:Bind ExifToolPath, Mode=TwoWay}" />
                                        <Button Click="BrowseExifTool_Click" Content="Browse" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="16">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Time Alignment" />
                                <TextBlock Opacity="0.75" Text="Use a positive or negative offset when the camera clock was off. The adjusted time is what GPX matching uses." TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <NumberBox
                                        x:Name="OffsetMinutesBox"
                                        Width="160"
                                        Header="Camera offset (minutes)"
                                        SmallChange="1"
                                        SpinButtonPlacementMode="Compact"
                                        Value="{x:Bind OffsetMinutes, Mode=TwoWay}" />
                                    <CheckBox
                                        VerticalAlignment="Bottom"
                                        Content="Rewrite capture time on save"
                                        IsChecked="{x:Bind RewriteCaptureTime, Mode=TwoWay}" />
                                </StackPanel>
                                <TextBlock Text="{x:Bind OffsetSummary, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="16">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Manual Pinning" />
                                <TextBlock Text="{x:Bind MapClickSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <Button Click="TagSelectedAtClick_Click" Content="Tag Selected At Last Map Click" HorizontalAlignment="Left" />
                                <TextBlock Opacity="0.75" Text="You can also drag selected rows into the map drop target after choosing a point on the map." TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Selection" />
                                <TextBlock Text="{x:Bind SelectionSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border
                    x:Name="VerticalSplitter"
                    Grid.Column="1"
                    Margin="0,4"
                    Background="{ThemeResource TextFillColorSecondaryBrush}"
                    CornerRadius="4"
                    Opacity="0.18"
                    PointerCanceled="VerticalSplitter_PointerCanceled"
                    PointerCaptureLost="VerticalSplitter_PointerCaptureLost"
                    PointerMoved="VerticalSplitter_PointerMoved"
                    PointerPressed="VerticalSplitter_PointerPressed"
                    PointerReleased="VerticalSplitter_PointerReleased"
                    AutomationProperties.Name="Resize left and right panes"
                    AutomationProperties.AutomationId="VerticalPaneSplitter" />

                <Grid Grid.Column="2" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Image Preview" />
                        <TextBlock Opacity="0.72" Text="Select a single photo to load an in-app preview." />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        CornerRadius="20">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind SelectedPhotoPreviewTitle, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Opacity="0.72"
                                    Text="{x:Bind SelectedPhotoPreviewStatus, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Border
                                Grid.Row="1"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="16">
                                <Image
                                    Source="{x:Bind SelectedPhotoPreviewSource, Mode=OneWay}"
                                    Stretch="Uniform"
                                    AutomationProperties.Name="Selected photo preview"
                                    AutomationProperties.AutomationId="SelectedPhotoPreviewImage" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Map Preview" />
                            <TextBlock Opacity="0.72" Text="Blue track = GPX, markers = matched or manually pinned photos." />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="14"
                            AllowDrop="True"
                            DragOver="MapDropTarget_DragOver"
                            Drop="MapDropTarget_Drop">
                            <StackPanel Width="220" Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="Drop Selected Photos Here" />
                                <TextBlock FontSize="12" Opacity="0.72" Text="Click the map first, then drag rows here to assign that point." TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="20">
                        <WebView2
                            x:Name="MapView"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            NavigationCompleted="MapView_NavigationCompleted" />
                    </Border>
                </Grid>
            </Grid>

            <Border
                x:Name="HorizontalSplitter"
                Grid.Row="3"
                Margin="12,0,12,0"
                Background="{ThemeResource TextFillColorSecondaryBrush}"
                CornerRadius="4"
                Opacity="0.18"
                PointerCanceled="HorizontalSplitter_PointerCanceled"
                PointerCaptureLost="HorizontalSplitter_PointerCaptureLost"
                PointerMoved="HorizontalSplitter_PointerMoved"
                PointerPressed="HorizontalSplitter_PointerPressed"
                PointerReleased="HorizontalSplitter_PointerReleased"
                AutomationProperties.Name="Resize top and bottom panes"
                AutomationProperties.AutomationId="HorizontalPaneSplitter" />

            <Border Grid.Row="4" Margin="12,0,12,12" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="4,0,4,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Photos" />
                            <TextBlock Opacity="0.72" Text="Detailed list with capture times, adjusted times, and coordinate state." />
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Bottom" Text="{x:Bind PhotoCountSummary, Mode=OneWay}" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Padding="8,0,24,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="175" />
                                <ColumnDefinition Width="175" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="File" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Capture Time" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Updated Time" />
                            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Latitude" />
                            <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Longitude" />
                            <TextBlock Grid.Column="5" FontWeight="SemiBold" Text="Source" />
                            <TextBlock Grid.Column="6" FontWeight="SemiBold" Text="Status" />
                        </Grid>

                        <ListView
                            x:Name="PhotoListView"
                            Grid.Row="1"
                            CanDragItems="True"
                            IsMultiSelectCheckBoxEnabled="True"
                            ItemsSource="{x:Bind Photos, Mode=OneWay}"
                            SelectionMode="Extended"
                            SelectionChanged="PhotoListView_SelectionChanged"
                            DragItemsStarting="PhotoListView_DragItemsStarting">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:PhotoItem">
                                    <Grid MinHeight="42" Padding="8,8,24,8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="175" />
                                            <ColumnDefinition Width="175" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind CaptureTimeDisplay}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind AdjustedCaptureTimeDisplay}" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind LatitudeDisplay}" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind LongitudeDisplay}" />
                                        <TextBlock Grid.Column="5" Text="{x:Bind CoordinateSource}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="6" Text="{x:Bind Status}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
